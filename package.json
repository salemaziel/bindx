{
	"name": "@contember/bindx-monorepo",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --build --watch",
		"typecheck": "tsc --build",
		"test": "bun test tests/unit tests/react tests/cases tests/*.test.ts tests/*.test.tsx",
		"test:browser": "bun test tests/browser/",
		"test:all": "bun test",
		"playground": "cd packages/example && bun run dev",
		"playground:contember": "cd packages/example && VITE_CONTEMBER_API_URL=http://localhost:1581 VITE_CONTEMBER_API_TOKEN=0000000000000000000000000000000000000000 bun run dev",
		"contember:up": "docker compose up -d",
		"contember:migrate": "docker compose run --rm contember-cli migrations:execute --yes",
		"contember:diff": "docker compose run --rm contember-cli migrations:diff",
		"contember:seed": "bun run packages/example/seed.ts",
		"generate:schema": "bun run packages/bindx-generator/src/generate.ts packages/example/api/index.ts packages/example/generated"
	},
	"devDependencies": {
		"@contember/bindx": "workspace:*",
		"@contember/bindx-react": "workspace:*",
		"@happy-dom/global-registrator": "^20.0.11",
		"@testing-library/react": "^16.3.1",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.2",
		"bun-types": "^1.3.5",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "^5.3.0",
		"vite": "^7.3.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/contember/bindx.git"
	},
	"version": "0.1.33"
}
